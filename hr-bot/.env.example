# Application Settings
APP_NAME=hr-bot
DEBUG=false
HOST=0.0.0.0
PORT=8000

# LLM Settings (vLLM)
VLLM_HOST=localhost
VLLM_PORT=8001
VLLM_MODEL=Qwen/Qwen-14B-Chat
OPENAI_API_BASE=http://localhost:8001/v1
OPENAI_API_KEY=not-needed

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
EMBEDDING_DEVICE=cuda

# Vector Database
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=hr_knowledge

# SQLite Database
DATABASE_URL=sqlite+aiosqlite:///./data/hr_database.db

# Feishu Webhook Settings
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
FEISHU_WEBHOOK_SECRET=your_webhook_secret_here

# Alert Settings
CONTRACT_ALERT_DAYS=30
PERFORMANCE_THRESHOLD=60.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/hr-bot.log
